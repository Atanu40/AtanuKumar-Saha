{% style %}
  .section-{{ section.id }}-margin {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-margin {
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{% endstyle %}


<div class="section-{{ section.id }}-margin">
  <div class="color-{{ section.settings.color_scheme }} gradient gen-py-[15px]">
    <div class="{% if section.settings.container_section == 'fit' %} page-width {% endif %}">
      {% if section.settings.notice_text_lg != blank %}
        <p class="gen-hidden min-[750px]:gen-block gen-text-center gen-text-[16px] min-[1200px]:gen-text-[18px] gen-font-normal gen-leading-[13.42px] gen-tracking-[0px] {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in {% endif %}">{{ section.settings.notice_text_lg }}</p>
      {% endif %}
      {% if section.settings.notice_text_sm != blank %}
        <p class="gen-block min-[750px]:gen-hidden gen-text-center gen-text-[15px] gen-font-normal gen-leading-[13.42px] gen-tracking-[0px] {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in {% endif %}">{{ section.settings.notice_text_sm }}</p>
      {% endif %}
    </div>
  </div>
</div>


{% schema %}
  {
    "name": "Notice Bar",
    "tag": "section",
    "class": "section",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "settings": [
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:sections.all.colors.label",
        "default": "scheme-1"
      },
      {
        "type": "select",
        "id": "container_section",
        "label": "Section Width",
        "options": [
          {
            "value": "fit",
            "label": "Fit"
          },
          {
            "value": "fill",
            "label": "Fill"
          }
        ],
        "default": "fit"
      },
      {
        "type": "text",
        "id": "notice_text_lg",
        "label": "Notice text for large screens",
        "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
      },
      {
        "type": "text",
        "id": "notice_text_sm",
        "label": "Notice text for small screens",
        "default": "SUSTAINABLE, ETHICALLY MADE ACTIVEWEAR"
      },
      {
        "type": "header",
        "content": "Section Margin"
      },
      {
        "type": "range",
        "id": "margin_top",
        "min": -100,
        "max": 300,
        "step": 4,
        "unit": "px",
        "label": "Margin Top",
        "default": 0
      },
      {
        "type": "range",
        "id": "margin_bottom",
        "min": 0,
        "max": 300,
        "step": 4,
        "unit": "px",
        "label": "Margin Bottom",
        "default": 0
      },
    ],
    "presets": [
      {
        "name": "Notice Bar",
      }
    ]
  }
{% endschema %}